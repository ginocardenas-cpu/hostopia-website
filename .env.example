# Sanity (optional — build works without these; set in Vercel for CMS content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# ElevenLabs ElevenAgents — voice lead assistant (optional; omit agent id to hide the widget)
# Create an agent in ElevenLabs and add client tools: hostopia_submit_lead, hostopia_open_qualified_booking
# See lib/voice-lead/tools.ts for parameter shapes.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Official convai widget on the home page (after CTA). Set this OR use EMBED_ON_HOME + AGENT_ID above.
NEXT_PUBLIC_ELEVENLABS_CONVAI_AGENT_ID=
# Set to "true" to show the home convai widget using NEXT_PUBLIC_ELEVENLABS_AGENT_ID (if CONVAI_AGENT_ID is unset).
NEXT_PUBLIC_ELEVENLABS_EMBED_ON_HOME=
# If ElevenLabs gives a different script URL in their embed snippet, paste it here (optional).
NEXT_PUBLIC_ELEVENLABS_CONVAI_SCRIPT_URL=
# Calendly, Cal.com, HubSpot meetings, or internal booking page for qualified prospects
NEXT_PUBLIC_QUALIFIED_BOOKING_URL=

# Optional: POST JSON leads to Zapier / Slack / CRM (same shape as /api/voice-lead/ingest body + receivedAt)
VOICE_LEAD_FORWARD_URL=
VOICE_LEAD_FORWARD_SECRET=
